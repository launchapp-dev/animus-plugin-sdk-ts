{
  "name": "@launchapp-dev/animus-plugin-sdk",
  "version": "0.1.1",
  "description": "TypeScript SDK for authoring Animus plugins. Zod-typed, Rust protocol is the source of truth. Covers subject, provider, trigger, transport, log-storage, queue, workflow-runner, durable-store, memory-store, and notifier roles.",
  "license": "Elastic-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./subject": {
      "types": "./dist/subject.d.ts",
      "import": "./dist/subject.js"
    },
    "./trigger": {
      "types": "./dist/trigger.d.ts",
      "import": "./dist/trigger.js"
    },
    "./provider": {
      "types": "./dist/provider.d.ts",
      "import": "./dist/provider.js"
    },
    "./transport": {
      "types": "./dist/transport.d.ts",
      "import": "./dist/transport.js"
    },
    "./log-storage": {
      "types": "./dist/log-storage.d.ts",
      "import": "./dist/log-storage.js"
    },
    "./queue": {
      "types": "./dist/queue.d.ts",
      "import": "./dist/queue.js"
    },
    "./workflow-runner": {
      "types": "./dist/workflow-runner.d.ts",
      "import": "./dist/workflow-runner.js"
    },
    "./durable-store": {
      "types": "./dist/durable-store.d.ts",
      "import": "./dist/durable-store.js"
    },
    "./memory-store": {
      "types": "./dist/memory-store.d.ts",
      "import": "./dist/memory-store.js"
    },
    "./notifier": {
      "types": "./dist/notifier.d.ts",
      "import": "./dist/notifier.js"
    }
  },
  "files": [
    "dist",
    "src",
    "schemas",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "codegen": "node scripts/codegen.mjs",
    "codegen:check": "node scripts/codegen-check.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@types/node": ">=20.0.0"
  },
  "peerDependenciesMeta": {
    "@types/node": {
      "optional": false
    }
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/launchapp-dev/animus-plugin-sdk-ts"
  },
  "bugs": {
    "url": "https://github.com/launchapp-dev/animus-plugin-sdk-ts/issues"
  },
  "homepage": "https://github.com/launchapp-dev/animus-plugin-sdk-ts#readme",
  "author": "launchapp-dev",
  "keywords": [
    "animus",
    "plugin",
    "sdk",
    "jsonrpc",
    "stdio",
    "zod"
  ]
}
